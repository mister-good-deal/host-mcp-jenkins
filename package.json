{
    "name": "@mister-good-deal/host-mcp-jenkins",
    "version": "0.2.3",
    "description": "Local MCP server for Jenkins — replicates the Jenkins MCP Server Plugin by calling Jenkins REST API, no plugin installation required",
    "packageManager": "pnpm@10.29.2",
    "type": "module",
    "bin": {
        "host-mcp-jenkins": "dist/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsx src/index.ts",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "NODE_OPTIONS='--experimental-vm-modules --disable-warning=ExperimentalWarning' jest --config jest.config.ts",
        "test:integration": "NODE_OPTIONS='--experimental-vm-modules --disable-warning=ExperimentalWarning' jest --config jest.integration.config.ts --testTimeout=30000",
        "prepublishOnly": "pnpm run build"
    },
    "keywords": [
        "mcp",
        "jenkins",
        "ci",
        "cd",
        "model-context-protocol",
        "ai",
        "llm"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mister-good-deal/host-mcp-jenkins"
    },
    "bugs": {
        "url": "https://github.com/mister-good-deal/host-mcp-jenkins/issues"
    },
    "homepage": "https://github.com/mister-good-deal/host-mcp-jenkins#readme",
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "commander": "^14.0.3",
        "winston": "^3.19.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.9.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.0.0",
        "eslint": "^10.0.2",
        "globals": "^17.3.0",
        "jest": "^30.2.0",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    }
}
